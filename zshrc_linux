# zshrc_linux
# Symlink this to ~/.zshrc:  ln -sf ~/repos/dotfiles/zshrc_linux ~/.zshrc
source "${0:A:h}/zshrc_common"

# make ctrl-a / ctrl-e shorctus work https://stackoverflow.com/questions/23128353/zsh-shortcut-ctrl-a-not-working
bindkey -e

# Repos checked out on this machine
REPOS=(sarlet dolphin sweets apertools sardem sentineleof snaphu-py spurs opera-utils burst_db orca COMPASS s1-reader)

# ISCE2
export ISCE_BUILD_ROOT="${REPODIR}/isce2/build/"
export ISCE_INSTALL_ROOT="${REPODIR}/isce2/install/"
export ISCE_HOME=$ISCE_INSTALL_ROOT/packages/isce
export PYTHONPATH=$ISCE_INSTALL_ROOT/packages:$PYTHONPATH
export path=($ISCE_HOME/applications $ISCE_INSTALL_ROOT/bin $path)

# Headless display / threading
export MPLBACKEND="agg"
export OMP_NUM_THREADS=4
export OPENBLAS_NUM_THREADS=1

# SAR utilities
mdxunw() {
    xsize=$(gdalinfo -json $1 | jq .size[0])
    linebytes=$(( 4 * ${xsize} ))
    mdx "$1" -cols ${xsize} -wrap 9.42 -rhdr $linebytes -CW -unw -r4 -cmap cmy
}
xsize() { gdalinfo -json $1 | jq .size[0] }
ysize() { gdalinfo -json $1 | jq .size[1] }

alias claude-yolo='claude --dangerously-skip-permissions'

# --- Package management: conda or pixi (auto-detected) ---
if [[ -d "$HOME/.pixi" ]]; then
    export PATH="$HOME/.pixi/bin:$PATH"
    function pixi-shell() {
        local curdir="$(pwd)"
        cd ~/repos/pixi-envs/$1
        pixi shell
        cd "$curdir"
    }
    alias pixi-map="pixi-shell mapping-313"
fi
if [[ -f "$HOME/miniforge3/bin/conda" ]]; then
    __conda_setup="$("$HOME/miniforge3/bin/conda" 'shell.zsh' 'hook' 2> /dev/null)"
    if [ $? -eq 0 ]; then
        eval "$__conda_setup"
    else
        if [ -f "$HOME/miniforge3/etc/profile.d/conda.sh" ]; then
            . "$HOME/miniforge3/etc/profile.d/conda.sh"
        else
            export PATH="$HOME/miniforge3/bin:$PATH"
        fi
    fi
    unset __conda_setup
fi
